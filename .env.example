MBVM_DB_HOST=127.0.0.1
MBVM_DB_NAME=mbvm_school
MBVM_DB_USER=root
MBVM_DB_PASS=
MBVM_ADMIN_USERNAME=admin
MBVM_ADMIN_PASSWORD=change-this-before-hosting
# Prefer this on hosting. Generate with:
# php -r "echo password_hash('your-strong-password', PASSWORD_DEFAULT), PHP_EOL;"
MBVM_ADMIN_PASSWORD_HASH=
# Set to 1 only while running backend/setup_database.php, then remove or set back to 0.
MBVM_ALLOW_SETUP=0
# Optional: Google Apps Script webhook URL for auto-syncing new contact/admission/result records.
MBVM_SHEETS_WEBHOOK_URL= https://script.google.com/macros/s/AKfycbys2F_K5mXjAhBOlZqlsFjy7or8fg1LMSdLnMImpXhkgIe2zcuxiY_GhWfLTu4qjo92Mw/exec
# Optional: Secret token checked by the Google Apps Script webhook.
MBVM_SHEETS_WEBHOOK_SECRET= mbvm-school-secret-2026
