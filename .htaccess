Options -Indexes

<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "(^composer\.(json|lock)$|^package(-lock)?\.json$|^webpack\.config\.js$)">
    Require all denied
</FilesMatch>

RewriteEngine On
RewriteBase /

RewriteRule ^frontend/(.*)$ src/$1 [L]

RewriteRule ^events/?$ events.php [L]
RewriteRule ^gallery/?$ gallery.php [L]
RewriteRule ^results/?$ results.php [L]
RewriteRule ^teachers/?$ teachers.php [L]
RewriteRule ^admin/?$ dashboard.php [L]
RewriteRule ^health/?$ backend/health.php [L]
RewriteRule ^contact/?$ contact-us.html [L]

RewriteRule ^events\.html$ events.php [L,R=302]
RewriteRule ^gallery\.html$ gallery.php [L,R=302]
RewriteRule ^results\.html$ results.php [L,R=302]
RewriteRule ^teachers\.html$ teachers.php [L,R=302]

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>
